# ---------- App ----------
# Public base URL of this Next.js app. Used to build OAuth redirect URLs and links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------- GitHub Models (LLM + embeddings) ----------
# Personal access token with access to https://models.github.ai/inference
# Used for both chat completions and text embeddings.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional overrides (defaults shown).
GH_MODELS_CHAT=openai/gpt-4.1-mini
GH_MODELS_EMBED=openai/text-embedding-3-small

# ---------- Supabase ----------
# Find all of these in: Supabase dashboard -> Project -> Settings -> API Keys.
# As of 2025 Supabase is migrating from JWT-based anon/service_role keys to
# publishable/secret keys. Use the new ones when possible.
# Docs: https://supabase.com/docs/guides/api/api-keys

# Project URL (e.g. https://abcd1234.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# --- Client (browser) key — safe to expose ---
# Preferred: publishable key (format sb_publishable_...)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
# Legacy JWT anon key (fallback). The app reads PUBLISHABLE first, then ANON.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# --- Server key — SERVER ONLY, NEVER expose to the browser ---
# Preferred: secret key (format sb_secret_...). Blocked by Supabase if sent from a browser.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx
# Legacy JWT service_role key (fallback). Reads SECRET first, then SERVICE_ROLE.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ---------- Google OAuth (Gmail read-only) ----------
# Create an OAuth 2.0 Client ID (Web application) in Google Cloud Console.
# Authorized redirect URI MUST match GOOGLE_REDIRECT_URI below.
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
